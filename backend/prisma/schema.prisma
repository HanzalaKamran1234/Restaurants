datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Profile {
  id             String         @id // Clerk User ID or Mock ID
  email          String         @unique
  fullName       String
  imageUrl       String?
  phone          String?
  whatsapp       String?
  loyaltyPoints  Int            @default(0)
  role           String         @default("customer") // "admin" or "customer"
  password       String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  addresses      Address[]
  orders         Order[]
  reviews        Review[]
  favorites      Favorite[]
  cartItems      CartItem[]
  notifications  Notification[]
}

model Address {
  id             String        @id @default(uuid())
  title          String        @default("Home") // e.g. "Home", "Office"
  profileId      String
  profile        Profile       @relation(fields: [profileId], references: [id], onDelete: Cascade)
  fullAddress    String
  city           String        @default("Karachi")
  province       String        @default("Sindh")
  postalCode     String?       @default("74600")
  phone          String?
  isDefault      Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  orders         Order[]
}

model Category {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  image     String
  products  Product[]
}

model Collection {
  id          String    @id @default(uuid())
  name        String    // e.g., "Winter Classics", "Essentials"
  slug        String    @unique
  description String?
  image       String?
  active      Boolean   @default(true)
  products    Product[]
}

model Product {
  id           String           @id @default(uuid())
  name         String
  description  String
  price        Float
  discount     Float            @default(0) // Discount percentage
  rating       Float            @default(4.5)
  fabric       String?          @default("100% Luxury Long-Staple Cotton")
  fit          String?          @default("Relaxed Fit")
  shippingInfo String?          @default("Standard premium shipping 2-3 business days. Free shipping on orders over Rs. 5000.")
  returnsInfo  String?          @default("30-day complimentary returns and exchanges. Items must be in original condition with tags.")
  available    Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  
  categoryId   String
  category     Category         @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  
  collectionId String?
  collection   Collection?      @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  
  images       ProductImage[]
  variants     ProductVariant[]
  reviews      Review[]
  favorites    Favorite[]
  cartItems    CartItem[]
  orderItems   OrderItem[]
}

model ProductImage {
  id        String   @id @default(uuid())
  url       String
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductVariant {
  id        String      @id @default(uuid())
  productId String
  product   Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  color     String      // e.g., "Black", "Ivory", "Camel"
  size      String      // e.g., "S", "M", "L", "XL"
  sku       String?     @unique
  inventory Int         @default(10)
  cartItems CartItem[]
  orderItems OrderItem[]
}

model Favorite {
  id         String   @id @default(uuid())
  profileId  String
  profile    Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([profileId, productId])
}

model CartItem {
  id         String          @id @default(uuid())
  profileId  String
  profile    Profile         @relation(fields: [profileId], references: [id], onDelete: Cascade)
  productId  String
  product    Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId  String?
  variant    ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  quantity   Int             @default(1)
  size       String          @default("M")
  color      String          @default("Black")
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@unique([profileId, productId, size, color])
}

model Order {
  id              String      @id @default(uuid())
  orderNumber     String      @unique // e.g. "VST-000001"
  profileId       String?
  profile         Profile?    @relation(fields: [profileId], references: [id], onDelete: SetNull)
  status          String      @default("PENDING") // PENDING, PROCESSING, SHIPPED, DELIVERED, CANCELLED
  subtotal        Float
  shippingCharge  Float       @default(200)
  discountAmount  Float       @default(0)
  tax             Float       @default(0)
  finalAmount     Float
  paymentMethod   String      @default("COD") // COD, CARD, JAZZCASH, EASYPAISA
  shippingAddress String
  addressId       String?
  address         Address?    @relation(fields: [addressId], references: [id], onDelete: SetNull)
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  items           OrderItem[]
}

model OrderItem {
  id         String          @id @default(uuid())
  orderId    String
  order      Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId  String
  product    Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId  String?
  variant    ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  quantity   Int
  price      Float
  color      String          @default("Black")
  size       String          @default("M")
}

model Review {
  id         String   @id @default(uuid())
  rating     Int      @default(5)
  comment    String
  approved   Boolean  @default(true)
  featured   Boolean  @default(false)
  profileId  String
  profile    Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  subject   String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model NewsletterSubscriber {
  id        String   @id @default(uuid())
  email     String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model WebsiteSetting {
  id    String @id @default(uuid())
  key   String @unique // e.g. "logo_text", "website_status"
  value String
}

model Notification {
  id        String   @id @default(uuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}
